# ─── Filtering (required) ──────────────────────────────────────────────────────
JOB_TITLES="engineer,developer,analyst,data scientist"
IGNORE_TITLES="manager,director,principal,intern"
COUNTRIES="united states,usa"
STATES="california,new york,texas"
STATES_ABBR="ca,ny,tx"
POSTING_DIFF=10

WORKDAY_OFFSET=200

# ─── Dice API ──────────────────────────────────────────────────────────────────
DICE_API_KEY=your-dice-api-key-here

# ─── Infrastructure ────────────────────────────────────────────────────────────
# RABBITMQ_URL is only required for the /workday endpoint
RABBITMQ_URL=amqp://localhost
STATSD_HOST=localhost
STATSD_PORT=8125
NODE_ENV=development
HEALTH_CHECK="Server is good"

# ─── Email ─────────────────────────────────────────────────────────────────────
# Get a token at https://mailtrap.io → Settings → API Tokens
MAILTRAP_TOKEN=your-mailtrap-token-here
EMAIL_RECIPIENT=your-email@example.com
MAIL_FROM_EMAIL=mailtrap@demomailtrap.com
MAIL_FROM_NAME=Job Alerts

# ─── CORS ──────────────────────────────────────────────────────────────────────
CORS_ORIGIN=http://localhost:3000

# ─── Rate Limiting ─────────────────────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=300000
RATE_LIMIT_MAX=5
